00500093  // addi x1, x0, 5    (x1 = 5)
00700113  // addi x2, x0, 7    (x2 = 7)
002081B3  // add  x3, x1, x2   (x3 = 12, 驗證 ALU)
00312023  // sw   x3, 0(x2)    (Mem[7] = 12, 驗證 S-type/DMEM)
00012203  // lw   x4, 0(x2)    (x4 = 12, 驗證 I-type/Load)  <--- [修正這裡] 
00418463  // beq  x3, x4, 8    (Jump 8 bytes, 驗證 Branch)
00100093  // addi x1, x0, 1    (這行應該被跳過)
00c000ef  // jal  x1, 12       (跳到 PC+12，並將返回位址存入 x1, 驗證 J-type)